# App
NODE_ENV=development
PORT=3000
APP_NAME=ROOSTAY
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roostay
DB_USER=postgres
DB_PASSWORD=your_password
DB_MAX_CONNECTIONS=20

# JWT Auth
JWT_SECRET=your_jwt_secret_change_this
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_this
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payment - Bank Transfer
BANK_NAME=Commercial Bank of Ethiopia
BANK_ACCOUNT_NUMBER=1000457856fr
BANK_ACCOUNT_HOLDER=ROOSTAY PLC

# Payment - Telebirr
TELEBIRR_MERCHANT_ID=your_merchant_id
TELEBIRR_API_KEY=your_api_key
TELEBIRR_SHORTCODE=123456

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
