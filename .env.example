# roostay\.env.example


# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
PORT=3000
APP_NAME=ROOSTAY
APP_URL=http://localhost:3000

# ============================================================================
# DATABASE (Neon PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://user:password@host:port/dbname

# ============================================================================
# JWT AUTHENTICATION (Secrets — generate strong random values for production)
# ============================================================================
JWT_SECRET=your_jwt_secret_change_this
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_this
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# CLOUDINARY (Image Storage)
# ============================================================================
CLOUDINARY_CLOUD_NAME=zaw6fxxm
CLOUDINARY_API_KEY=191316595662292
CLOUDINARY_API_SECRET=x3SX_z7tDowDw4GavJQZ64uKmE4

# ============================================================================
# TELEBIRR API (Secrets for API integration — not the public shortcode)
# ============================================================================
TELEBIRR_MERCHANT_ID=your_merchant_id
TELEBIRR_API_KEY=your_api_key

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# UPSTASH REDIS (Distributed Rate Limiting)
# ============================================================================
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ============================================================================
# PAYMENT TIMEOUT
# ============================================================================
PAYMENT_TIMEOUT_MINUTES=30